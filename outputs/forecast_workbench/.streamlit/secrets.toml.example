# Copy this file to `.streamlit/secrets.toml` (which is git-ignored) and fill in
# your real values. On Streamlit Community Cloud, paste the same keys into
# Settings → Secrets instead of using a file.

# ── Persistence ────────────────────────────────────────────────────────────
# Supabase: Project → Settings → Database → Connection string (URI).
# Use the "Connection pooling" (Transaction) URI for serverless/Streamlit.
# It looks like:
#   postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL = "postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres"

# ── AI layer (Phase 5 — optional for now) ───────────────────────────────────
ANTHROPIC_API_KEY = ""
# GEMINI_API_KEY = ""
